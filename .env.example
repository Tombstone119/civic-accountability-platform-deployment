# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# MongoDB connection string (use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — generate a strong random string for production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# The deployed frontend URL — used by the backend to set CORS allowed origins
# Example: https://civic-accountability-platform.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── Client (prefix with VITE_ so Vite exposes them to the browser) ────────────
# In development this is proxied by Vite, so you can leave it blank or set /api
# In production set it to your deployed backend URL + /api
# Example: https://civic-accountability-api.vercel.app/api
VITE_API_URL=/api
